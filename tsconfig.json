{
	"compilerOptions": {
		"moduleResolution": "node",
		"target": "ES6",
		"module": "ESNext",
		"lib": ["DOM", "ES2021"],
		"allowJs": true,
		"noImplicitAny": true,
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"types": ["node"]
	},
	"include": ["**/*.ts"]
}
